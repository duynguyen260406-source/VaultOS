# Production profile: tighten transport, cookie, and DB verification by default.
DB_HOST=prod-db-host
DB_PORT=3306
DB_NAME=banking_system
DB_ENCRYPTION_KEY=replace_with_a_strong_unique_key
DB_ENCRYPTION_KEY_VERSION=1
DB_HASH_PEPPER=replace_with_a_separate_hash_pepper
DB_CONTEXT_SIGNING_KEY=replace_with_a_separate_db_context_signing_key
DB_REQUIRE_TLS=true
DB_ALLOW_ROLE_FALLBACK=false
DB_SSL_MODE=
DB_SSL_CA=/etc/ssl/certs/mysql-ca.pem
DB_SSL_CERT=
DB_SSL_KEY=
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=true

DB_AUTH_USER=app_auth_user
DB_AUTH_PASSWORD=replace_app_auth_db_password
DB_AUTH_HOST=prod-db-host

DB_ADMIN_HOST=prod-db-host
DB_ADMIN_PORT=3306
DB_ADMIN_USER=replace_admin_user
DB_ADMIN_PASSWORD=replace_admin_password

DB_MANAGER_USER=manager_user
DB_MANAGER_PASSWORD=replace_manager_db_password
DB_MANAGER_HOST=prod-db-host

DB_TELLER_USER=teller_user
DB_TELLER_PASSWORD=replace_teller_db_password
DB_TELLER_HOST=prod-db-host

DB_AUDITOR_USER=auditor_user
DB_AUDITOR_PASSWORD=replace_auditor_db_password
DB_AUDITOR_HOST=prod-db-host

DB_BACKUP_USER=backup_user
DB_BACKUP_PASSWORD=replace_backup_db_password
DB_BACKUP_HOST=prod-db-host

JWT_SECRET_KEY=replace_with_a_long_random_jwt_secret
AUTH_LOCK_THRESHOLD=5
AUTH_IP_LOCK_THRESHOLD=10
AUTH_IP_LOCK_WINDOW_SECONDS=300
SESSION_TTL_HOURS=8
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=example.com
CSRF_PROTECTION=true

APP_FORCE_HTTPS=true
APP_EXPOSE_DOCS=false
APP_SECURITY_HEADERS=true
APP_CONTENT_SECURITY_POLICY=
APP_TRUSTED_HOSTS=app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

BACKUP_ENCRYPTION_PASSPHRASE=
BACKUP_ENCRYPTION_KEY_FILE=
