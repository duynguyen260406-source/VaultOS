# Shared database location
DB_HOST=localhost
DB_PORT=3306
DB_NAME=banking_system
DB_ENCRYPTION_KEY=replace_with_a_strong_unique_key
DB_ENCRYPTION_KEY_VERSION=1
DB_HASH_PEPPER=replace_with_a_separate_hash_pepper
DB_CONTEXT_SIGNING_KEY=replace_with_a_separate_db_context_signing_key
# Set the flags below to false only for local development without TLS/HTTPS.
DB_REQUIRE_TLS=true
DB_ALLOW_ROLE_FALLBACK=false
DB_SSL_MODE=
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=true

# Dedicated app auth account used for login/password changes on AppUsers
DB_AUTH_USER=app_auth_user
DB_AUTH_PASSWORD=replace_app_auth_db_password
DB_AUTH_HOST=localhost

# Legacy fallback shared DB connection (optional for local troubleshooting)
DB_USER=root
DB_PASSWORD=

# Admin account used only by scripts/bootstrap_security.py
DB_ADMIN_HOST=localhost
DB_ADMIN_PORT=3306
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=

# Role-specific MySQL users for DB-level RBAC
DB_MANAGER_USER=manager_user
DB_MANAGER_PASSWORD=replace_manager_db_password
DB_MANAGER_HOST=localhost

DB_TELLER_USER=teller_user
DB_TELLER_PASSWORD=replace_teller_db_password
DB_TELLER_HOST=localhost

DB_AUDITOR_USER=auditor_user
DB_AUDITOR_PASSWORD=replace_auditor_db_password
DB_AUDITOR_HOST=localhost

# Dedicated backup account for mysqldump
DB_BACKUP_USER=backup_user
DB_BACKUP_PASSWORD=replace_backup_db_password
DB_BACKUP_HOST=localhost

# Application auth secrets
JWT_SECRET_KEY=replace_with_a_long_random_jwt_secret
AUTH_LOCK_THRESHOLD=5
AUTH_IP_LOCK_THRESHOLD=10
AUTH_IP_LOCK_WINDOW_SECONDS=300
SESSION_TTL_HOURS=8
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
CSRF_PROTECTION=true

# API runtime hardening
APP_FORCE_HTTPS=true
APP_EXPOSE_DOCS=false
APP_SECURITY_HEADERS=true
APP_CONTENT_SECURITY_POLICY=
APP_TRUSTED_HOSTS=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001

# Optional backup-at-rest encryption for scripts/backup.sh and scripts/restore.sh
BACKUP_ENCRYPTION_PASSPHRASE=
BACKUP_ENCRYPTION_KEY_FILE=
